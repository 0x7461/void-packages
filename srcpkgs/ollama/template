# Template file for 'ollama'
# Uses pre-built binaries from official releases
pkgname=ollama
version=0.17.6
revision=1
archs="x86_64"
create_wrksrc=yes
short_desc="Get up and running with large language models locally"
maintainer="ta <ta@localhost>"
license="MIT"
homepage="https://ollama.com"
changelog="https://github.com/ollama/ollama/releases"
distfiles="https://github.com/ollama/ollama/releases/download/v${version}/ollama-linux-amd64.tar.zst"
checksum=95a53478846ee38765ac9c8be713457634fc3e4b8c69801132bef769ce98bd00
nostrip=yes

do_install() {
	# Install main binary
	vbin bin/ollama

	# Install GPU runners and support libs
	vmkdir usr/lib/ollama
	vcopy "lib/ollama/*" usr/lib/ollama
}
